# ProteticFlow - Configurações de Produção
# IMPORTANTE: Altere todos os valores antes de usar em produção!

# Django Configuration
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_SECRET_KEY_IN_PRODUCTION
DEBUG=False
ALLOWED_HOSTS=proteticflow.com,www.proteticflow.com,localhost

# Database Configuration (PostgreSQL)
DB_NAME=proteticflow
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Security Settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# CORS Settings
CORS_ALLOWED_ORIGINS=https://proteticflow.com,https://www.proteticflow.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AI/ML Settings
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# File Upload Settings
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=INFO

# Monitoring (opcional)
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD
SENTRY_DSN=your-sentry-dsn-here

